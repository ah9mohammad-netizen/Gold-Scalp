# ========================================================
# XAU-USDT Gold Edge v4 — Paper Trading & Telegram
# ========================================================

ENV=production
PAPER_TRADING=true
PAPER_BALANCE=100.00

SYMBOL=XAU-USDT
EXCHANGE_ID=bybit
TIMEFRAME=5m
POLL_INTERVAL_SECONDS=5.0

# Book risk
MAX_LEVERAGE=50
RISK_PER_TRADE_PCT=1.0
MAX_SPREAD_USD=0.35
MAX_OPEN_TRADES=1
MAX_DAILY_LOSS_PCT=4.0
MAX_TRADES_PER_DAY=2
ENTRY_COOLDOWN_SECONDS=900
LOSS_COOLDOWN_SECONDS=1800
MARGIN_CAP_PCT=35.0

# Sessions UTC — London core (backtest-best)
ALLOWED_SESSIONS=8-11
ASIAN_START_HOUR_UTC=0
ASIAN_END_HOUR_UTC=7
NY_ORB_START_HOUR_UTC=13
NY_ORB_END_HOUR_UTC=16
NY_ORB_DECISION_HOUR_UTC=16

# Indicators
EMA_TREND_PERIOD=200
EMA_FAST_PERIOD=50
EMA_PULLBACK_PERIOD=21
ATR_PERIOD=14
RSI_PERIOD=14
RSI_OVERBOUGHT=68.0
RSI_OVERSOLD=32.0
ADX_PERIOD=14
ADX_RANGE_MAX=20.0
ADX_TREND_MIN=28.0
MIN_DI_SPREAD=8.0

# Structure
SWEEP_MIN_PIERCE_USD=0.80
MIN_ASIAN_RANGE_USD=5.00
MAX_ASIAN_RANGE_USD=35.00
BREAKOUT_BUFFER_USD=0.40
ENABLE_EMA_PULLBACK=true
ENABLE_SWEEP_FADE=false
ENABLE_ASIA_BREAKOUT=false
ENABLE_NY_ORB=false
REQUIRE_TURN_CONFIRM=true
REQUIRE_EMA_STACK=true
REQUIRE_CLOSE_BEYOND=true

# Cost / vol
ROUND_TRIP_COST_USD=0.40
MIN_SL_COST_MULTIPLE=5.0
MIN_TP_COST_MULTIPLE=8.0
MIN_ATR_USD=1.00

# Exits — v4 core fix
SL_ATR_MULTIPLIER=1.8
MIN_SL_USD=1.50
TP_RR_RATIO=2.0
BE_TRIGGER_RR=1.5
TRAIL_ATR_MULTIPLIER=2.5
ENABLE_TRAIL=false

# Railway Volume
DB_PATH=/data/history.db
DATABASE_URL=sqlite:////data/history.db

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

APEX_API_KEY=
APEX_API_SECRET=
APEX_PASSPHRASE=
