# ========================================================
# XAU-USDT Gold Edge v5 — Z-Score Mean Reversion
# ========================================================

ENV=production
PAPER_TRADING=true
PAPER_BALANCE=100.00

SYMBOL=XAU-USDT
EXCHANGE_ID=bybit
TIMEFRAME=5m
POLL_INTERVAL_SECONDS=5.0

# Book risk
MAX_LEVERAGE=50
RISK_PER_TRADE_PCT=1.0
MAX_SPREAD_USD=0.40
MAX_OPEN_TRADES=1
MAX_DAILY_LOSS_PCT=4.0
MAX_TRADES_PER_DAY=3
ENTRY_COOLDOWN_SECONDS=600
LOSS_COOLDOWN_SECONDS=1200
MARGIN_CAP_PCT=35.0

# Sessions UTC — London through NY
ALLOWED_SESSIONS=7-17

# Z-Score MR (PRIMARY)
ENABLE_ZSCORE_MR=true
ZSCORE_PERIOD=20
ZSCORE_ENTRY=2.2
ADX_RANGE_MAX=18.0
REQUIRE_TURN_CONFIRM=true

# Failed research setups — keep OFF
ENABLE_EMA_PULLBACK=false
ENABLE_SWEEP_FADE=false
ENABLE_ASIA_BREAKOUT=false
ENABLE_NY_ORB=false

# Indicators
EMA_TREND_PERIOD=200
EMA_FAST_PERIOD=50
EMA_PULLBACK_PERIOD=21
ATR_PERIOD=14
RSI_PERIOD=14
ADX_PERIOD=14

# Exits — fixed RR, no early BE
SL_ATR_MULTIPLIER=2.5
MIN_SL_USD=2.00
TP_RR_RATIO=2.0
BE_TRIGGER_RR=9.0
ENABLE_TRAIL=false

# Cost / vol gates
ROUND_TRIP_COST_USD=0.40
MIN_SL_COST_MULTIPLE=5.0
MIN_TP_COST_MULTIPLE=8.0
MIN_ATR_USD=0.80
ATR_VS_AVG_MIN=0.40
ATR_VS_AVG_MAX=2.00

# Railway Volume
DB_PATH=/data/history.db
DATABASE_URL=sqlite:////data/history.db

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

APEX_API_KEY=
APEX_API_SECRET=
APEX_PASSPHRASE=
